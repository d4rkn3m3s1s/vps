NODE_ENV=development
PORT=4000
APP_NAME=VPS Emulator Platform
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vps_emulator
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=ChangeMe123!
DEFAULT_API_KEY=replace-with-a-long-random-api-key
ADB_BIN=adb
DOCKER_BIN=docker
EMULATOR_IMAGE=budtmo/docker-android-x86-11.0
UPLOAD_DIR=./storage
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
META_CLIENT_ID=
META_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
SOCIAL_CRYPTO_KEY=
