# ─────────────────────────────────────────────────────────────────────────────
# VPS Fleet — API environment.  Copy to `.env` and fill in real values.
# NEVER commit the real .env (it is gitignored).  Generate all secrets fresh
# for each environment — do not reuse the dev values in production.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=production
PORT=4000
APP_NAME="VPS Fleet API"
# Public URLs (used in emails, Stripe redirects, CORS).
API_BASE_URL=https://api.yourdomain.com
WEB_BASE_URL=https://app.yourdomain.com

# ── Data stores ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/vps_fleet?schema=public
REDIS_URL=redis://HOST:6379

# ── Auth secrets (REQUIRED, must be strong) ──────────────────────────────────
# Generate each with:  openssl rand -hex 32   (min 32 chars)
JWT_ACCESS_SECRET=change-me-32+chars-random
JWT_REFRESH_SECRET=change-me-different-32+chars-random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Bootstrap admin (created on first boot; password is re-hashed every start).
# CHANGE THESE before production — never ship the default.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=use-a-long-random-password-here

# Service API key the dashboard + host agents authenticate with (min 16 chars).
# Generate with:  openssl rand -hex 24
DEFAULT_API_KEY=change-me-min-16-chars

# Encrypts at-rest secrets (social tokens, Vast.ai keys). Generate: openssl rand -hex 32
SOCIAL_CRYPTO_KEY=change-me-32+chars-random

# ── Host / emulator tooling ──────────────────────────────────────────────────
ADB_BIN=adb
DOCKER_BIN=docker
EMULATOR_IMAGE=budtmo/docker-android-x86-11.0
UPLOAD_DIR=./storage

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Email (SMTP). Leave SMTP_HOST blank to log emails to console (dev). ───────
MAIL_FROM="VPS Fleet <no-reply@yourdomain.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# ── AI automation (Anthropic Claude). Powers natural-language → RPA flow. ────
# Leave ANTHROPIC_API_KEY blank to disable the AI builder (UI hides it).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Billing (Stripe — TEST keys in non-prod). Leave blank to disable billing. ─
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=

# ── Social OAuth (optional integrations) ─────────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
META_CLIENT_ID=
META_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Note: Vast.ai API keys are NOT set here — each workspace stores its own key
# (encrypted) via the dashboard at Admin → GPU servers.
