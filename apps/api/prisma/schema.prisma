generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmulatorStatus {
  PENDING
  RUNNING
  STOPPED
  FAILED
  DELETED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum JobType {
  EMULATOR_CREATE
  EMULATOR_START
  EMULATOR_STOP
  EMULATOR_DELETE
  EMULATOR_INSTALL_APK
  EMULATOR_SCREENSHOT
  EMULATOR_SHELL
  EMULATOR_OPEN_APP
  EMULATOR_CLOSE_APP
  EMULATOR_PUSH_FILE
  EMULATOR_SET_PROXY
  RPA_RUN
}

enum HostStatus {
  ONLINE
  OFFLINE
  DEGRADED
}

// A registered KVM/emulator host that runs cloud phones. The install.sh agent
// registers and heartbeats; the dashboard shows capacity and health.
model Host {
  id          String     @id @default(cuid())
  name        String
  address     String
  region      String?
  status      HostStatus @default(OFFLINE)
  capacity    Int        @default(0)
  runningPhones Int      @default(0)
  cpuCores    Int?
  memoryGb    Int?
  kvm         Boolean    @default(true)
  agentKeyHash String?
  lastSeenAt  DateTime?
  // Cloud provider this host was provisioned from (e.g. "vast"), and the
  // provider-side instance/contract id so we can manage (destroy) it later.
  provider       String?
  vastInstanceId String?
  workspaceId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  devices     Device[]
  claimedJobs Job[]
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  STARTING
  STOPPING
  ERROR
  UPDATING
  REBOOTING
}

enum SocialProvider {
  X
  META
  INSTAGRAM
}

enum ProxyType {
  HTTP
  HTTPS
  SOCKS5
}

enum ProxyStatus {
  UNKNOWN
  OK
  FAILED
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  role           String          @default("admin")
  // Two-factor auth (TOTP). Secret is stored AES-256-GCM encrypted; backup
  // codes are stored as sha256 hashes (one-time use).
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[]  @default([])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  // Stable, human-friendly referral code (generated on first visit to /referral).
  referralCode   String?         @unique
  refreshTokens  RefreshToken[]
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  socialAccounts SocialAccount[]
  memberships    WorkspaceMember[]
  referrals      Referral[]      @relation("Referrer")
}

// One row per person invited via a referral link. Created when a referred user
// signs up; status advances to CONVERTED (and a reward is credited) when they
// start a paid plan.
enum ReferralStatus {
  INVITED
  SIGNED_UP
  CONVERTED
}

model Referral {
  id            String         @id @default(cuid())
  referrerId    String
  referredEmail String
  status        ReferralStatus @default(SIGNED_UP)
  rewardCents   Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  referrer      User           @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

// A tenant boundary. Every fleet resource (devices, proxies, jobs, …) belongs to
// exactly one workspace; members access only their workspaces.
model Workspace {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     WorkspaceMember[]
  subscription Subscription?
  devices       Device[]
  deviceGroups  DeviceGroup[]
  proxies       Proxy[]
  jobs          Job[]
  rpaFlows      RpaFlow[]
  schedules     ScheduledTask[]
  farmCampaigns FarmCampaign[]
  farmAccounts  FarmAccount[]
  webhooks      Webhook[]
  hosts         Host[]
  libraryAssets LibraryAsset[]
  socialAccounts SocialAccount[]
  alertRules    AlertRule[]
  alertEvents   AlertEvent[]
  settings      WorkspaceSettings?
}

// One-to-one policy/configuration row for a workspace. Persisted security
// policies that the API enforces (require2fa, restrictInvites) plus advisory
// preferences surfaced in the admin UI.
model WorkspaceSettings {
  id               String    @id @default(cuid())
  workspaceId      String    @unique
  require2fa       Boolean   @default(false)
  restrictInvites  Boolean   @default(true)
  strongPasswords  Boolean   @default(true)
  sessionExpiryHrs Int       @default(12)
  // Vast.ai GPU-host provider API key (AES-GCM encrypted; never returned raw).
  vastApiKey       String?
  updatedAt        DateTime  @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// Join table: which user belongs to which workspace, with what role.
model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String    @default("operator") // admin | operator | viewer
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum AlertTrigger {
  JOB_FAILED
  DEVICE_OFFLINE
  QUOTA_HIGH
  HOST_OFFLINE
}

// A user-defined alerting rule, scoped to a workspace. When its trigger
// condition occurs the engine creates an AlertEvent and optionally notifies.
model AlertRule {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  trigger     AlertTrigger
  // Optional threshold (e.g. quota percent for QUOTA_HIGH). 0 = not used.
  threshold   Int          @default(0)
  notify      Boolean      @default(true)  // push to the notification center
  webhook     Boolean      @default(false) // also fire outbound webhooks
  email       Boolean      @default(false) // also email workspace admins
  active      Boolean      @default(true)
  lastFiredAt DateTime?
  fireCount   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  events      AlertEvent[]

  @@index([workspaceId])
}

// A recorded firing of an alert rule.
model AlertEvent {
  id          String     @id @default(cuid())
  ruleId      String
  workspaceId String
  title       String
  detail      String
  acknowledged Boolean   @default(false)
  createdAt   DateTime   @default(now())
  rule        AlertRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([ruleId])
}

// Billing state for a workspace. `plan` is one of the keys in billing.plans.ts
// (free | pro | scale). Stripe identifiers link to the test-mode customer +
// subscription; null while on the free plan.
model Subscription {
  id                   String             @id @default(cuid())
  workspaceId          String             @unique
  plan                 String             @default("free")
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String?
  workspaceId String?
  keyPrefix   String   @unique
  keyHash     String   @unique
  name        String
  scopes      String[] @default([])
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Emulator {
  id            String         @id @default(cuid())
  name          String
  image         String
  status        EmulatorStatus  @default(PENDING)
  containerId   String?         @unique
  adbHost       String?
  adbPort       Int?
  metadata      Json?
  createdById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  jobs          Job[]
}

model DeviceGroup {
  id          String    @id @default(cuid())
  name        String
  description String?
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  devices     Device[]
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns   FarmCampaign[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Device {
  id             String        @id @default(cuid())
  uuid           String        @unique @default(cuid())
  name           String
  status         DeviceStatus  @default(OFFLINE)
  ipAddress      String?
  adbPort        Int?
  androidVersion String?
  cpuUsage       Float         @default(0)
  memoryUsage    Float         @default(0)
  diskUsage      Float         @default(0)
  lastSeen       DateTime?
  metadata       Json?
  groupId        String?
  hostId         String?
  workspaceId    String?
  // External ADB access (TCP bridge). When exposed, the host agent forwards the
  // device's ADB to a public host:port, optionally restricted to an IP allowlist.
  adbExposed     Boolean       @default(false)
  adbPublicHost  String?
  adbPublicPort  Int?
  adbAllowlist   String[]      @default([])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  group          DeviceGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  host           Host?         @relation(fields: [hostId], references: [id], onDelete: SetNull)
  workspace      Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Anti-detection device fingerprint (one per cloud phone).
  fingerprint    DeviceFingerprint?
  schedules      ScheduledTask[]
  farmAccount    FarmAccount?

  @@index([workspaceId])
}

// A randomized hardware/identity fingerprint bound to a single cloud phone so
// each profile looks like a distinct physical device.
model DeviceFingerprint {
  id            String   @id @default(cuid())
  deviceId      String   @unique
  imei          String
  androidId     String
  serialNo      String
  macAddress    String
  manufacturer  String
  model         String
  brand         String
  osVersion     String
  buildNumber   String
  resolution    String
  dpi           Int
  carrier       String
  mcc           String
  mnc           String
  phoneNumber   String?
  language      String   @default("en")
  // GPS / SIM geolocation simulation.
  country       String   @default("US")
  countryCode   String   @default("US")
  timezone      String   @default("America/New_York")
  latitude      Float?
  longitude     Float?
  gpsEnabled    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model Job {
  id          String     @id @default(cuid())
  emulatorId  String?
  type        JobType
  status      JobStatus  @default(PENDING)
  payload     Json
  result      Json?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  claimedByHostId String?
  claimedAt   DateTime?
  workspaceId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  emulator    Emulator?  @relation(fields: [emulatorId], references: [id], onDelete: SetNull)
  claimedBy   Host?      @relation(fields: [claimedByHostId], references: [id], onDelete: SetNull)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AuditLog {
  id          String    @id @default(cuid())
  userId      String?
  action      String
  resourceType String
  resourceId  String?
  requestId   String?
  ip          String?
  userAgent   String?
  metadata    Json?
  workspaceId String?
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model SocialAccount {
  id                 String         @id @default(cuid())
  provider           SocialProvider
  providerAccountId  String
  userId             String
  displayName        String?
  username           String?
  accessTokenEnc     String
  refreshTokenEnc    String?
  tokenExpiresAt     DateTime?
  scopes             String[]       @default([])
  metadata           Json?
  workspaceId        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace          Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([workspaceId])
}

enum LibraryAssetType {
  IMAGE
  VIDEO
  APK
  COOKIE
  OTHER
}

model LibraryAsset {
  id          String           @id @default(cuid())
  name        String
  type        LibraryAssetType @default(OTHER)
  sizeBytes   Int              @default(0)
  url         String?
  tags        String[]         @default([])
  metadata    Json?
  workspaceId String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  workspace   Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Proxy {
  id          String       @id @default(cuid())
  label       String
  type        ProxyType    @default(HTTP)
  host        String
  port        Int
  username    String?
  // Encrypted at rest (AES-256-GCM). Never returned to clients in plaintext.
  password    String?
  group       String?
  isp         String?
  remarks     String?
  exportIp    String?
  status      ProxyStatus  @default(UNKNOWN)
  lastCheckedAt DateTime?
  workspaceId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

enum ScheduleStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum ScheduleRepeat {
  ONCE
  HOURLY
  DAILY
  WEEKLY
}

// A recurring or one-off automation task bound to a cloud phone.
model ScheduledTask {
  id          String         @id @default(cuid())
  name        String
  deviceId    String?
  jobType     JobType
  payload     Json
  repeat      ScheduleRepeat @default(ONCE)
  status      ScheduleStatus @default(ACTIVE)
  nextRunAt   DateTime
  lastRunAt   DateTime?
  runCount    Int            @default(0)
  workspaceId String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  device      Device?        @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  workspace   Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// Per-account engagement metrics powering the AI Analytics dashboard.
model ContentMetric {
  id          String   @id @default(cuid())
  accountId   String?
  provider    String
  date        DateTime @default(now())
  posts       Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  followers   Int      @default(0)
  reach       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([provider, date])
}

// Installable app in the Applications catalog.
model AppCatalogItem {
  id          String   @id @default(cuid())
  name        String
  packageName String   @unique
  version     String
  category    String   @default("Social")
  shortLabel  String
  color       String   @default("#3a4256")
  iconUrl     String?
  apkUrl      String?
  installs    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// A pre-built automation template shown in the Automation marketplace.
model AutomationTemplate {
  id          String   @id @default(cuid())
  title       String
  description String
  platform    String
  color       String   @default("#3a4256")
  jobType     JobType  @default(EMULATOR_OPEN_APP)
  payload     Json     @default("{}")
  recommended Boolean  @default(false)
  uses        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ListingCategory {
  TEMPLATE
  AUTOMATION
  INTEGRATION
}

// A FleetHub marketplace listing.
model MarketplaceListing {
  id          String          @id @default(cuid())
  title       String
  description String
  category    ListingCategory @default(TEMPLATE)
  icon        String          @default("◈")
  price       String          @default("Free")
  installs    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// A visual RPA automation flow: an ordered list of steps (tap/type/wait/swipe/
// open-app/shell) that can be dispatched as a job to one or more cloud phones.
model RpaFlow {
  id          String   @id @default(cuid())
  name        String
  description String?
  steps       Json     @default("[]")
  runCount    Int      @default(0)
  lastRunAt   DateTime?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns   FarmCampaign[]

  @@index([workspaceId])
}

// ── Farm system ─────────────────────────────────────────────────────────────
// A farm campaign runs an RPA flow across a target device group on a humanized
// schedule to age/warm up the accounts on those cloud phones.
enum FarmStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model FarmCampaign {
  id            String     @id @default(cuid())
  name          String
  status        FarmStatus @default(ACTIVE)
  rpaFlowId     String?
  groupId       String?
  // Humanization: each device runs the flow at a random interval between these
  // bounds, capped at maxActionsPerDay, only within [activeFromHour, activeToHour).
  minIntervalMin Int       @default(45)
  maxIntervalMin Int       @default(180)
  maxActionsPerDay Int     @default(20)
  activeFromHour Int       @default(8)
  activeToHour   Int       @default(23)
  jitterPct      Int       @default(25)
  // Engine bookkeeping.
  nextRunAt     DateTime   @default(now())
  lastRunAt     DateTime?
  runCount      Int        @default(0)
  workspaceId   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  rpaFlow       RpaFlow?   @relation(fields: [rpaFlowId], references: [id], onDelete: SetNull)
  group         DeviceGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// Per-device warmup / account-maturity tracking. One row per cloud phone that
// participates in farming.
model FarmAccount {
  id            String   @id @default(cuid())
  deviceId      String   @unique
  warmupStage   Int      @default(1)     // 1=new … 5=mature
  daysActive    Int      @default(0)
  actionsToday  Int      @default(0)
  totalActions  Int      @default(0)
  healthScore   Int      @default(100)   // 0-100; drops on errors
  lastActionAt  DateTime?
  dayAnchor     DateTime @default(now()) // when actionsToday was last reset
  workspaceId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

enum WebhookEvent {
  JOB_COMPLETED
  JOB_FAILED
  DEVICE_ONLINE
  DEVICE_OFFLINE
  QUOTA_HIGH
  ALERT_FIRED
  ALL
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

// Outbound webhook: POSTs a JSON payload to `url` when a matching event fires.
model Webhook {
  id          String       @id @default(cuid())
  label       String
  url         String
  event       WebhookEvent @default(ALL)
  secret      String?
  active      Boolean      @default(true)
  lastFiredAt DateTime?
  failCount   Int          @default(0)
  workspaceId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([workspaceId])
}

// One delivery attempt-set for a single event to a single webhook. The queue
// retries on failure (backoff); each terminal outcome is recorded here for the
// delivery-history UI and manual redelivery.
model WebhookDelivery {
  id           String                @id @default(cuid())
  webhookId    String
  event        WebhookEvent
  payload      Json
  status       WebhookDeliveryStatus @default(PENDING)
  attempts     Int                   @default(0)
  responseCode Int?
  error        String?
  createdAt    DateTime              @default(now())
  deliveredAt  DateTime?
  webhook      Webhook               @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
}

// Restricts a member's access to specific device groups (profile-level perms).
model ProfilePermission {
  id          String   @id @default(cuid())
  userId      String
  groupId     String?
  deviceId    String?
  canView     Boolean  @default(true)
  canControl  Boolean  @default(false)
  canDelete   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([userId, groupId, deviceId])
}
