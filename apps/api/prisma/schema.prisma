generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmulatorStatus {
  PENDING
  RUNNING
  STOPPED
  FAILED
  DELETED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum JobType {
  EMULATOR_CREATE
  EMULATOR_START
  EMULATOR_STOP
  EMULATOR_DELETE
  EMULATOR_INSTALL_APK
  EMULATOR_SCREENSHOT
  EMULATOR_SHELL
  EMULATOR_OPEN_APP
  EMULATOR_CLOSE_APP
  EMULATOR_PUSH_FILE
  EMULATOR_SET_PROXY
  RPA_RUN
  EMULATOR_SNAPSHOT_CREATE
  EMULATOR_SNAPSHOT_RESTORE
  EMULATOR_RESET
  EMULATOR_PULL_FILE
  EMULATOR_CLIPBOARD_SET
  EMULATOR_CLIPBOARD_GET
}

enum HostStatus {
  ONLINE
  OFFLINE
  DEGRADED
}

// A registered KVM/emulator host that runs cloud phones. The install.sh agent
// registers and heartbeats; the dashboard shows capacity and health.
model Host {
  id          String     @id @default(cuid())
  name        String
  address     String
  region      String?
  status      HostStatus @default(OFFLINE)
  capacity    Int        @default(0)
  runningPhones Int      @default(0)
  cpuCores    Int?
  memoryGb    Int?
  kvm         Boolean    @default(true)
  agentKeyHash String?
  lastSeenAt  DateTime?
  // Cloud provider this host was provisioned from (e.g. "vast"), and the
  // provider-side instance/contract id so we can manage (destroy) it later.
  provider       String?
  vastInstanceId String?
  workspaceId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  devices     Device[]
  claimedJobs Job[]
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  STARTING
  STOPPING
  ERROR
  UPDATING
  REBOOTING
}

enum SocialProvider {
  X
  META
  INSTAGRAM
}

enum ProxyType {
  HTTP
  HTTPS
  SOCKS5
}

enum ProxyStatus {
  UNKNOWN
  OK
  FAILED
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  role           String          @default("admin")
  // Two-factor auth (TOTP). Secret is stored AES-256-GCM encrypted; backup
  // codes are stored as sha256 hashes (one-time use).
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[]  @default([])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  // Stable, human-friendly referral code (generated on first visit to /referral).
  referralCode   String?         @unique
  refreshTokens  RefreshToken[]
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  socialAccounts SocialAccount[]
  memberships    WorkspaceMember[]
  referrals      Referral[]      @relation("Referrer")
}

// One row per person invited via a referral link. Created when a referred user
// signs up; status advances to CONVERTED (and a reward is credited) when they
// start a paid plan.
enum ReferralStatus {
  INVITED
  SIGNED_UP
  CONVERTED
}

model Referral {
  id            String         @id @default(cuid())
  referrerId    String
  referredEmail String
  status        ReferralStatus @default(SIGNED_UP)
  rewardCents   Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  referrer      User           @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

// A tenant boundary. Every fleet resource (devices, proxies, jobs, …) belongs to
// exactly one workspace; members access only their workspaces.
model Workspace {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     WorkspaceMember[]
  subscription Subscription?
  devices       Device[]
  deviceGroups  DeviceGroup[]
  proxies       Proxy[]
  jobs          Job[]
  rpaFlows      RpaFlow[]
  schedules     ScheduledTask[]
  farmCampaigns FarmCampaign[]
  farmAccounts  FarmAccount[]
  webhooks      Webhook[]
  hosts         Host[]
  libraryAssets LibraryAsset[]
  resourceGuides ResourceGuide[]
  socialAccounts SocialAccount[]
  alertRules    AlertRule[]
  alertEvents   AlertEvent[]
  snapshots     DeviceSnapshot[]
  scheduledPosts ScheduledPost[]
  settings      WorkspaceSettings?
}

// One-to-one policy/configuration row for a workspace. Persisted security
// policies that the API enforces (require2fa, restrictInvites) plus advisory
// preferences surfaced in the admin UI.
model WorkspaceSettings {
  id               String    @id @default(cuid())
  workspaceId      String    @unique
  require2fa       Boolean   @default(false)
  restrictInvites  Boolean   @default(true)
  strongPasswords  Boolean   @default(true)
  sessionExpiryHrs Int       @default(12)
  // Vast.ai GPU-host provider API key (AES-GCM encrypted; never returned raw).
  vastApiKey       String?
  updatedAt        DateTime  @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// Join table: which user belongs to which workspace, with what role.
model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String    @default("operator") // admin | operator | viewer
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum AlertTrigger {
  JOB_FAILED
  DEVICE_OFFLINE
  QUOTA_HIGH
  HOST_OFFLINE
  FARM_BAN_RISK
}

// A user-defined alerting rule, scoped to a workspace. When its trigger
// condition occurs the engine creates an AlertEvent and optionally notifies.
model AlertRule {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  trigger     AlertTrigger
  // Optional threshold (e.g. quota percent for QUOTA_HIGH). 0 = not used.
  threshold   Int          @default(0)
  notify      Boolean      @default(true)  // push to the notification center
  webhook     Boolean      @default(false) // also fire outbound webhooks
  email       Boolean      @default(false) // also email workspace admins
  active      Boolean      @default(true)
  lastFiredAt DateTime?
  fireCount   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  events      AlertEvent[]

  @@index([workspaceId])
}

// A recorded firing of an alert rule.
model AlertEvent {
  id          String     @id @default(cuid())
  ruleId      String
  workspaceId String
  title       String
  detail      String
  acknowledged Boolean   @default(false)
  createdAt   DateTime   @default(now())
  rule        AlertRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([ruleId])
}

// Billing state for a workspace. `plan` is one of the keys in billing.plans.ts
// (free | pro | scale). Stripe identifiers link to the test-mode customer +
// subscription; null while on the free plan.
model Subscription {
  id                   String             @id @default(cuid())
  workspaceId          String             @unique
  plan                 String             @default("free")
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String?
  workspaceId String?
  keyPrefix   String   @unique
  keyHash     String   @unique
  name        String
  scopes      String[] @default([])
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Emulator {
  id            String         @id @default(cuid())
  name          String
  image         String
  status        EmulatorStatus  @default(PENDING)
  containerId   String?         @unique
  adbHost       String?
  adbPort       Int?
  metadata      Json?
  createdById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  jobs          Job[]
}

model DeviceGroup {
  id          String    @id @default(cuid())
  name        String
  description String?
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  devices     Device[]
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns   FarmCampaign[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Device {
  id             String        @id @default(cuid())
  uuid           String        @unique @default(cuid())
  name           String
  status         DeviceStatus  @default(OFFLINE)
  ipAddress      String?
  adbPort        Int?
  androidVersion String?
  cpuUsage       Float         @default(0)
  memoryUsage    Float         @default(0)
  diskUsage      Float         @default(0)
  lastSeen       DateTime?
  metadata       Json?
  groupId        String?
  hostId         String?
  workspaceId    String?
  // External ADB access (TCP bridge). When exposed, the host agent forwards the
  // device's ADB to a public host:port, optionally restricted to an IP allowlist.
  adbExposed     Boolean       @default(false)
  adbPublicHost  String?
  adbPublicPort  Int?
  adbAllowlist   String[]      @default([])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  group          DeviceGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  host           Host?         @relation(fields: [hostId], references: [id], onDelete: SetNull)
  workspace      Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Anti-detection device fingerprint (one per cloud phone).
  fingerprint    DeviceFingerprint?
  schedules      ScheduledTask[]
  farmAccount    FarmAccount?
  snapshots      DeviceSnapshot[] @relation("DeviceSnapshotSource")
  grants         DeviceGrant[]    @relation("DeviceGrants")
  usage          DeviceUsage[]

  @@index([workspaceId])
}

// Per-device, per-day online-minute rollup for usage metering / pay-as-you-go
// billing. Accrued from heartbeats: when a device reports ONLINE, the minutes
// since its last heartbeat are added to today's bucket (capped so a long gap
// from a crashed agent doesn't over-bill).
model DeviceUsage {
  id            String   @id @default(cuid())
  deviceId      String
  day           DateTime @db.Date         // calendar day (UTC midnight)
  onlineMinutes Int      @default(0)
  workspaceId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, day])
  @@index([workspaceId, day])
}

// A randomized hardware/identity fingerprint bound to a single cloud phone so
// each profile looks like a distinct physical device.
model DeviceFingerprint {
  id            String   @id @default(cuid())
  deviceId      String   @unique
  imei          String
  androidId     String
  serialNo      String
  macAddress    String
  manufacturer  String
  model         String
  brand         String
  osVersion     String
  buildNumber   String
  resolution    String
  dpi           Int
  carrier       String
  mcc           String
  mnc           String
  phoneNumber   String?
  language      String   @default("en")
  // GPS / SIM geolocation simulation.
  country       String   @default("US")
  countryCode   String   @default("US")
  timezone      String   @default("America/New_York")
  latitude      Float?
  longitude     Float?
  gpsEnabled    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

model Job {
  id          String     @id @default(cuid())
  emulatorId  String?
  type        JobType
  status      JobStatus  @default(PENDING)
  payload     Json
  result      Json?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  claimedByHostId String?
  claimedAt   DateTime?
  workspaceId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  emulator    Emulator?  @relation(fields: [emulatorId], references: [id], onDelete: SetNull)
  claimedBy   Host?      @relation(fields: [claimedByHostId], references: [id], onDelete: SetNull)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AuditLog {
  id          String    @id @default(cuid())
  userId      String?
  action      String
  resourceType String
  resourceId  String?
  requestId   String?
  ip          String?
  userAgent   String?
  metadata    Json?
  workspaceId String?
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model SocialAccount {
  id                 String         @id @default(cuid())
  provider           SocialProvider
  providerAccountId  String
  userId             String
  displayName        String?
  username           String?
  accessTokenEnc     String
  refreshTokenEnc    String?
  tokenExpiresAt     DateTime?
  scopes             String[]       @default([])
  metadata           Json?
  workspaceId        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace          Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([workspaceId])
}

enum LibraryAssetType {
  IMAGE
  VIDEO
  APK
  COOKIE
  OTHER
}

model LibraryAsset {
  id          String           @id @default(cuid())
  name        String
  type        LibraryAssetType @default(OTHER)
  sizeBytes   Int              @default(0)
  url         String?
  tags        String[]         @default([])
  metadata    Json?
  workspaceId String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  workspace   Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// FAQ / how-to entries shown on the Resources page. DB-backed so operators can
// curate their own help content per workspace instead of it being hardcoded.
model ResourceGuide {
  id          String   @id @default(cuid())
  question    String
  answer      String
  sortOrder   Int      @default(0)
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Proxy {
  id          String       @id @default(cuid())
  label       String
  type        ProxyType    @default(HTTP)
  host        String
  port        Int
  username    String?
  // Encrypted at rest (AES-256-GCM). Never returned to clients in plaintext.
  password    String?
  group       String?
  isp         String?
  remarks     String?
  exportIp    String?
  // ISO country code for geo-matching a proxy to a device's locale (e.g. assign
  // a US exit to a US-fingerprinted phone). Set on import or detected on check.
  countryCode String?
  status      ProxyStatus  @default(UNKNOWN)
  lastCheckedAt DateTime?
  workspaceId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

enum ScheduleStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum ScheduleRepeat {
  ONCE
  HOURLY
  DAILY
  WEEKLY
}

// A recurring or one-off automation task bound to a cloud phone.
model ScheduledTask {
  id          String         @id @default(cuid())
  name        String
  deviceId    String?
  jobType     JobType
  payload     Json
  repeat      ScheduleRepeat @default(ONCE)
  status      ScheduleStatus @default(ACTIVE)
  nextRunAt   DateTime
  lastRunAt   DateTime?
  runCount    Int            @default(0)
  workspaceId String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  device      Device?        @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  workspace   Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// Per-account engagement metrics powering the AI Analytics dashboard.
model ContentMetric {
  id          String   @id @default(cuid())
  accountId   String?
  provider    String
  date        DateTime @default(now())
  posts       Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  followers   Int      @default(0)
  reach       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([provider, date])
}

// Installable app in the Applications catalog.
model AppCatalogItem {
  id          String   @id @default(cuid())
  name        String
  packageName String   @unique
  version     String
  category    String   @default("Social")
  shortLabel  String
  color       String   @default("#3a4256")
  iconUrl     String?
  apkUrl      String?
  installs    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// A pre-built automation template shown in the Automation marketplace.
model AutomationTemplate {
  id          String   @id @default(cuid())
  title       String
  description String
  platform    String
  color       String   @default("#3a4256")
  jobType     JobType  @default(EMULATOR_OPEN_APP)
  payload     Json     @default("{}")
  recommended Boolean  @default(false)
  uses        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ListingCategory {
  TEMPLATE
  AUTOMATION
  INTEGRATION
}

// A FleetHub marketplace listing.
model MarketplaceListing {
  id          String          @id @default(cuid())
  title       String
  description String
  category    ListingCategory @default(TEMPLATE)
  icon        String          @default("◈")
  price       String          @default("Free")
  // When set, installing the listing dispatches an EMULATOR_INSTALL_APK job per
  // selected device (same path as the app catalog). Listings without an apkUrl
  // are non-installable templates/integrations and only bump the counter.
  apkUrl      String?
  packageName String?
  installs    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// A visual RPA automation flow: an ordered list of steps (tap/type/wait/swipe/
// open-app/shell) that can be dispatched as a job to one or more cloud phones.
model RpaFlow {
  id          String   @id @default(cuid())
  name        String
  description String?
  steps       Json     @default("[]")
  runCount    Int      @default(0)
  lastRunAt   DateTime?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns   FarmCampaign[]
  earlyCampaigns  FarmCampaign[] @relation("FarmEarlyFlow")
  midCampaigns    FarmCampaign[] @relation("FarmMidFlow")
  matureCampaigns FarmCampaign[] @relation("FarmMatureFlow")

  @@index([workspaceId])
}

// ── Farm system ─────────────────────────────────────────────────────────────
// A farm campaign runs an RPA flow across a target device group on a humanized
// schedule to age/warm up the accounts on those cloud phones.
enum FarmStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model FarmCampaign {
  id            String     @id @default(cuid())
  name          String
  status        FarmStatus @default(ACTIVE)
  rpaFlowId     String?
  groupId       String?
  // Humanization: each device runs the flow at a random interval between these
  // bounds, capped at maxActionsPerDay, only within [activeFromHour, activeToHour).
  minIntervalMin Int       @default(45)
  maxIntervalMin Int       @default(180)
  maxActionsPerDay Int     @default(20)
  activeFromHour Int       @default(8)
  activeToHour   Int       @default(23)
  jitterPct      Int       @default(25)
  // Safety: rotate a proxy from the pool onto the device before each run, and
  // auto-pause a device whose health drops below this threshold (ban defense).
  rotateProxy        Boolean @default(false)
  autoPauseThreshold Int     @default(40)
  // Stage-aware warmup: optional override flows for early/mid/mature accounts.
  // When set, the engine picks the flow that matches a device's warmup stage
  // instead of the default rpaFlow (gentle behavior early, richer behavior late).
  earlyFlowId   String?    // stages 1-2 (new / warming)
  midFlowId     String?    // stage 3 (developing)
  matureFlowId  String?    // stages 4-5 (active / mature)
  // Engine bookkeeping.
  nextRunAt     DateTime   @default(now())
  lastRunAt     DateTime?
  runCount      Int        @default(0)
  workspaceId   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  rpaFlow       RpaFlow?   @relation(fields: [rpaFlowId], references: [id], onDelete: SetNull)
  earlyFlow     RpaFlow?   @relation("FarmEarlyFlow", fields: [earlyFlowId], references: [id], onDelete: SetNull)
  midFlow       RpaFlow?   @relation("FarmMidFlow", fields: [midFlowId], references: [id], onDelete: SetNull)
  matureFlow    RpaFlow?   @relation("FarmMatureFlow", fields: [matureFlowId], references: [id], onDelete: SetNull)
  group         DeviceGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  logs          FarmActionLog[]

  @@index([workspaceId])
}

// Per-device warmup / account-maturity tracking. One row per cloud phone that
// participates in farming.
model FarmAccount {
  id            String   @id @default(cuid())
  deviceId      String   @unique
  warmupStage   Int      @default(1)     // 1=new … 5=mature
  daysActive    Int      @default(0)
  actionsToday  Int      @default(0)
  totalActions  Int      @default(0)
  healthScore   Int      @default(100)   // 0-100; drops on errors
  consecutiveErrors Int  @default(0)      // resets on a clean run
  paused        Boolean  @default(false)  // auto-paused by ban defense
  pausedReason  String?
  lastActionAt  DateTime?
  dayAnchor     DateTime @default(now()) // when actionsToday was last reset
  // ── Proactive ban-risk scoring ──
  // 0-100 leading indicator (errors, velocity, proxy/stage mismatch). Persisted
  // so the engine can detect a *rising* trend and alert once per cooldown rather
  // than re-firing every tick while the device stays risky.
  riskScore     Int      @default(0)
  riskAlertedAt DateTime?
  // ── Account identity (the credentials being warmed up) ──
  // Which platform this account lives on, the public handle, and the secrets.
  // Secrets are AES-256-GCM encrypted at rest and NEVER returned to clients raw.
  platform      String?  // x | instagram | meta | tiktok | other
  username      String?
  emailAddress  String?
  passwordEnc   String?  // encrypted
  emailPasswordEnc String? // encrypted (recovery mailbox)
  totpSecretEnc String?  // encrypted 2FA seed
  // Operator notes + free-form tags for filtering ("aged", "buyer", "us-geo").
  notes         String?
  tags          String[] @default([])
  workspaceId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  logs          FarmActionLog[]

  @@index([workspaceId])
}

// Append-only timeline of what each farm account actually did. Written by the
// engine (dispatch) and the job pipeline (outcome), and rendered as a per-account
// audit trail so a ban can be traced back to "what were the last N actions".
model FarmActionLog {
  id          String   @id @default(cuid())
  deviceId    String
  campaignId  String?
  flowId      String?
  flowName    String?
  // dispatch | success | failure | paused | resumed | proxy_rotated | manual
  kind        String
  detail      String?
  warmupStage Int      @default(0)
  healthAfter Int?
  workspaceId String?
  createdAt   DateTime @default(now())
  account     FarmAccount?  @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
  campaign    FarmCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([deviceId])
  @@index([campaignId])
  @@index([workspaceId])
}

enum WebhookEvent {
  JOB_COMPLETED
  JOB_FAILED
  DEVICE_ONLINE
  DEVICE_OFFLINE
  QUOTA_HIGH
  ALERT_FIRED
  ALL
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

// Outbound webhook: POSTs a JSON payload to `url` when a matching event fires.
model Webhook {
  id          String       @id @default(cuid())
  label       String
  url         String
  event       WebhookEvent @default(ALL)
  secret      String?
  active      Boolean      @default(true)
  lastFiredAt DateTime?
  failCount   Int          @default(0)
  workspaceId String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([workspaceId])
}

// One delivery attempt-set for a single event to a single webhook. The queue
// retries on failure (backoff); each terminal outcome is recorded here for the
// delivery-history UI and manual redelivery.
model WebhookDelivery {
  id           String                @id @default(cuid())
  webhookId    String
  event        WebhookEvent
  payload      Json
  status       WebhookDeliveryStatus @default(PENDING)
  attempts     Int                   @default(0)
  responseCode Int?
  error        String?
  createdAt    DateTime              @default(now())
  deliveredAt  DateTime?
  webhook      Webhook               @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
}

// Restricts a member's access to specific device groups (profile-level perms).
model ProfilePermission {
  id          String   @id @default(cuid())
  userId      String
  groupId     String?
  deviceId    String?
  canView     Boolean  @default(true)
  canControl  Boolean  @default(false)
  canDelete   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([userId, groupId, deviceId])
}

// ── Device snapshots / image market ─────────────────────────────────────────
// A captured backup of a cloud phone's state (its /data, or a docker image ref)
// that can be restored onto the same device, cloned onto a new one, or published
// to the image market for the whole workspace (or publicly) to provision from.
enum SnapshotVisibility {
  PRIVATE    // only the creator
  WORKSPACE  // anyone in the workspace
  PUBLIC     // listed in the public image market
}

enum SnapshotStatus {
  PENDING    // capture job dispatched, not yet ready
  READY      // captured and restorable
  FAILED     // capture failed
}

model DeviceSnapshot {
  id            String             @id @default(cuid())
  name          String
  description   String?
  // Where the captured artifact lives on the host (tarball path or docker image
  // tag). The agent writes this back when the capture job completes.
  artifactRef   String?
  sizeBytes     BigInt             @default(0)
  androidVersion String?
  // Snapshot of the source device's fingerprint/app set for the market card.
  metadata      Json?
  tags          String[]           @default([])
  visibility    SnapshotVisibility @default(PRIVATE)
  status        SnapshotStatus     @default(PENDING)
  installs      Int                @default(0)  // how many devices provisioned from it
  sourceDeviceId String?
  workspaceId   String?
  createdById   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  sourceDevice  Device?            @relation("DeviceSnapshotSource", fields: [sourceDeviceId], references: [id], onDelete: SetNull)
  workspace     Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([visibility])
}

// ── Device authorization / transfer ─────────────────────────────────────────
// A time-boxed grant of access to a device for another user (think "lend this
// phone to a teammate for 24h"). Distinct from ProfilePermission (which is a
// standing workspace ACL); a grant is temporary, revocable, and audited.
enum GrantAccess {
  VIEW     // live screen only
  CONTROL  // screen + remote input + jobs
}

model DeviceGrant {
  id          String      @id @default(cuid())
  deviceId    String
  grantedToId String      // user receiving access
  grantedById String      // user who issued it
  access      GrantAccess @default(VIEW)
  expiresAt   DateTime?   // null = no expiry (until revoked)
  revokedAt   DateTime?
  workspaceId String?
  createdAt   DateTime    @default(now())
  device      Device      @relation("DeviceGrants", fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([grantedToId])
}

// ── Content calendar / scheduled posting ────────────────────────────────────
// A piece of content scheduled to be posted from one or more cloud phones at a
// future time. The scheduler tick dispatches the matching RPA flow with the
// content (caption + media) injected when scheduledFor passes.
enum ScheduledPostStatus {
  SCHEDULED
  POSTING
  POSTED
  FAILED
  CANCELED
}

model ScheduledPost {
  id           String              @id @default(cuid())
  caption      String
  platform     String              // tiktok | instagram | x | meta | youtube | other
  mediaUrl     String?             // image/video asset to push then post
  // Target: a device group (fan out to all) and/or explicit device ids, plus the
  // RPA flow that performs the actual posting steps on each device.
  groupId      String?
  deviceIds    String[]            @default([])
  rpaFlowId    String?
  scheduledFor DateTime
  status       ScheduledPostStatus @default(SCHEDULED)
  postedAt     DateTime?
  error        String?
  workspaceId  String?
  createdById  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  workspace    Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status, scheduledFor])
}
