# ─────────────────────────────────────────────────────────────────────────────
# VPS Fleet — Dashboard environment.  Copy to `.env` and fill in real values.
# The dashboard is server-rendered; these secrets stay server-side (the browser
# never sees them). NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# Where the API lives (server-to-server; can be an internal URL).
API_BASE_URL=https://api.yourdomain.com

# Must match the API's DEFAULT_API_KEY exactly.
DEFAULT_API_KEY=change-me-min-16-chars

# Service identity the dashboard logs in as. MUST match the API's
# ADMIN_EMAIL / ADMIN_PASSWORD exactly, or server-side data fetches fail.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=use-a-long-random-password-here

# Public WebSocket URL for the live device/job/alert feed (browser connects here).
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com/ws/devices

# Optional: Anthropic key for the in-app Fleet AI assistant.
ANTHROPIC_API_KEY=
