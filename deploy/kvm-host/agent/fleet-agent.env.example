# Copy to /etc/fleet-agent.env and fill in. The host agent reads these.
#
# Where your VPS Fleet API is reachable (no trailing slash):
FLEET_API_URL=https://api.your-domain.com

# Platform API key (the x-api-key the dashboard/API uses):
FLEET_API_KEY=replace-with-platform-api-key

# The one-time agent key shown ONCE when you registered this host in the
# dashboard (Hosts -> Register). If you lost it, delete and re-register the host.
FLEET_HOST_KEY=host_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional tuning:
# FLEET_POLL_MS=3000
# FLEET_HEARTBEAT_MS=30000
# FLEET_ADB=adb
