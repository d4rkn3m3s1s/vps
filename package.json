{
  "name": "vps-emulator-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @vps/api",
    "dev:api": "npm run dev --workspace @vps/api",
    "dev:web": "npm run dev --workspace @vps/web",
    "build": "npm run build --workspace @vps/api && npm run build --workspace @vps/web",
    "lint": "npm run lint --workspace @vps/api && npm run lint --workspace @vps/web",
    "db:generate": "npm run db:generate --workspace @vps/api",
    "db:migrate": "npm run db:migrate --workspace @vps/api",
    "db:seed": "npm run db:seed --workspace @vps/api"
  }
}
